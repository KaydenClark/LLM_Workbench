# Python
__pycache__/
*.pyc

# Generated eval artifacts (regenerate with the scripts; never commit as "data")
evals/results/_pipeline_selftest.jsonl

# Real run outputs are committed deliberately, not ignored, so the ledger has
# provenance — but scratch/temp runs can be prefixed tmp_ to skip them:
evals/results/tmp_*.jsonl

# macOS
.DS_Store

# Local-only reference material (owner decides if/when to publish)
research papers/

# Agent skills (installed via the `skills` CLI) — regenerable, machine-specific.
# Restore with: npx skills@latest experimental_install
# skills-lock.json is intentionally NOT ignored so installs stay reproducible.
/.agent/skills/
/agent/skills/
/.agents/
/.claude/skills/
